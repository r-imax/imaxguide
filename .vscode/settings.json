{
    "workbench.colorCustomizations": {
        "activityBar.background": "#00437A",
        "titleBar.activeBackground": "#00437A",
        "titleBar.activeForeground": "#ffffff",
        "titleBar.inactiveBackground": "#002F55",
        "titleBar.inactiveForeground": "#F5FAFF",
        "statusBar.background": "#002F55",
        "statusBar.foreground": "#F5FAFF",
        "statusBar.debuggingBackground": "#002F55",
        "statusBar.debuggingForeground": "#F5FAFF",
        "statusBar.noFolderBackground": "#002F55",
        "statusBar.noFolderForeground": "#F5FAFF"
    },
    "flake8.args": [
        "--max-line-length=125"
    ],
    "pylint.args": [
        "--max-line-length=125",
        "--disable=C0103"
    ]
}